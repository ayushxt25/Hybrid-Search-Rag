{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "fastapi",
  "buildCommand": "cd frontend && npm ci --cache /tmp/npm-cache && npm run build && cd .. && node scripts/prepare_vercel_static.mjs",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{**/.env,**/.env.*,**/.git/**,**/.vercel/**,**/.venv/**,backend/tests/**,build/**,deployment/**,frontend/{node_modules,.npm-cache,coverage}/**,logs/**,qdrant_storage/**,reports/**,storage/**,uploads/**,*.log}"
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/:path((?!api/v1).*)",
      "destination": "/index.html"
    }
  ]
}
