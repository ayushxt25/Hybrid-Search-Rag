APP_NAME=Hybrid Search RAG
APP_VERSION=0.1.0
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
OBSERVABILITY_ENABLED=true

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=internal_document_chunks
QDRANT_HYBRID_COLLECTION_NAME=internal_document_chunks_hybrid
DENSE_EMBEDDING_DIMENSIONS=384
HYBRID_DENSE_WEIGHT=1.5
HYBRID_SPARSE_WEIGHT=1.0
HYBRID_RRF_K=60
CONTEXT_MAX_CHARACTERS=12000
CONTEXT_MAX_SOURCES=8
CONTEXT_INCLUDE_METADATA_HEADERS=true
PROMPT_MAX_QUESTION_CHARACTERS=2000
PROMPT_REQUIRE_CITATIONS=true
PROMPT_ALLOW_GENERAL_KNOWLEDGE=false
GENERATION_REQUIRE_ANSWER_CITATIONS=true
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_GENERATION_MODEL=gpt-4.1-mini
OPENAI_GENERATION_TIMEOUT_SECONDS=30
OPENAI_GENERATION_MAX_RETRIES=2
GROUNDED_ANSWER_RATE_LIMIT_ENABLED=true
GROUNDED_ANSWER_RATE_LIMIT_REQUESTS=10
GROUNDED_ANSWER_RATE_LIMIT_WINDOW_SECONDS=60
