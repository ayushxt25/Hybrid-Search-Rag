# Hybrid Search Studio environment template.
# Copy this file to .env and replace placeholders in your deployment environment.
# Never commit real API keys, passwords, tokens, or plaintext service credentials.

# ---------------------------------------------------------------------------
# Local development
# ---------------------------------------------------------------------------

# Human-readable service metadata.
APP_NAME=Hybrid Search RAG
APP_VERSION=0.1.0

# Runtime mode label used by operators and health metadata.
ENVIRONMENT=development

# Backend API prefix. Frontend clients append route paths under this prefix.
API_V1_PREFIX=/api/v1

# Backend log level. Use INFO or higher for shared environments.
LOG_LEVEL=INFO

# Enable safe JSON request lifecycle and operational logs.
OBSERVABILITY_ENABLED=true

# Enable readiness checks for Qdrant and provider configuration.
READINESS_ENABLED=true

# Add conservative HTTP response security headers.
SECURITY_HEADERS_ENABLED=true

# Host headers accepted by the backend during local development.
TRUSTED_HOSTS=["localhost","127.0.0.1","testserver"]

# CORS is only needed when the frontend and backend use different origins.
CORS_ENABLED=false

# Local Vite dev origins. Keep empty when using the Docker reverse proxy.
CORS_ALLOWED_ORIGINS=[]

# Do not allow wildcard origins with credentials.
CORS_ALLOW_CREDENTIALS=false

# Maximum JSON API request size in bytes.
MAX_JSON_REQUEST_BYTES=262144

# Maximum uploaded document size in bytes.
MAX_DOCUMENT_UPLOAD_BYTES=10485760

# Local development can disable API auth. Production must enable it.
API_AUTH_ENABLED=false

# SHA-256 hex digest of the API key, never the plaintext API key.
API_AUTH_KEY_SHA256=

# Header used for API-key authentication.
API_AUTH_HEADER_NAME=X-API-Key

# Protect retrieval routes with API-key auth when API auth is enabled.
API_AUTH_PROTECT_SEARCH=true

# Local backend API URL for Vite development. Do not put secrets in VITE_* vars.
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Optional frontend-only display/validation upload limit. Leave unset for 10 MB local.
VITE_MAX_DOCUMENT_UPLOAD_BYTES=

# Docker Compose frontend build arg. Empty means use relative /api/v1.
FRONTEND_API_BASE_URL=

# Local Qdrant URL outside Docker. Compose overrides this to http://qdrant:6333.
QDRANT_URL=http://localhost:6333

# Optional Qdrant Cloud API key. Leave blank for local unauthenticated Qdrant.
QDRANT_API_KEY=

# Legacy dense collection name retained for compatibility.
QDRANT_COLLECTION_NAME=internal_document_chunks

# Hybrid collection used by ingestion, retrieval, and document management.
QDRANT_HYBRID_COLLECTION_NAME=internal_document_chunks_hybrid

# Qdrant readiness timeout in seconds.
QDRANT_HEALTH_TIMEOUT_SECONDS=3.0

# Dense embedding vector dimensionality expected by Qdrant.
DENSE_EMBEDDING_DIMENSIONS=384

# Dense embedding provider. Local Docker defaults to Sentence Transformers.
DENSE_EMBEDDING_PROVIDER=sentence_transformers

# Gemini embedding settings for Vercel. Keep GEMINI_API_KEY private.
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSION=768
GEMINI_EMBEDDING_TIMEOUT_SECONDS=30

# Hybrid retrieval weighting and RRF configuration.
HYBRID_DENSE_WEIGHT=1.5
HYBRID_SPARSE_WEIGHT=1.0
HYBRID_RRF_K=60

# Grounded-answer context and prompt limits.
CONTEXT_MAX_CHARACTERS=12000
CONTEXT_MAX_SOURCES=8
CONTEXT_INCLUDE_METADATA_HEADERS=true
PROMPT_MAX_QUESTION_CHARACTERS=2000
PROMPT_REQUIRE_CITATIONS=true
PROMPT_ALLOW_GENERAL_KNOWLEDGE=false
GENERATION_REQUIRE_ANSWER_CITATIONS=true

# Use deterministic locally when avoiding provider calls; use openai for real generation.
GENERATION_PROVIDER=openai

# External generation provider secret. Set only in private .env or secret manager.
OPENAI_API_KEY=

# Optional provider-compatible base URL. Leave empty for default OpenAI endpoint.
OPENAI_BASE_URL=

# Generation model and SDK retry/timeout settings.
OPENAI_GENERATION_MODEL=gpt-4.1-mini
OPENAI_GENERATION_TIMEOUT_SECONDS=30
OPENAI_GENERATION_MAX_RETRIES=2

# In-memory grounded-answer rate limit.
GROUNDED_ANSWER_RATE_LIMIT_ENABLED=true
GROUNDED_ANSWER_RATE_LIMIT_REQUESTS=10
GROUNDED_ANSWER_RATE_LIMIT_WINDOW_SECONDS=60

# ---------------------------------------------------------------------------
# Production placeholders
# ---------------------------------------------------------------------------

# Public backend origin, used for documentation and external probes.
# Example shape only: https://api.example.com
PUBLIC_BACKEND_URL=

# Frontend build API base URL. Prefer empty when reverse proxy serves /api/v1.
# Use a public HTTPS API URL only when frontend and API are on separate origins.
# Example shape only: https://api.example.com/api/v1
PRODUCTION_FRONTEND_API_BASE_URL=

# Production Qdrant endpoint. Use the provider URL from your secret manager.
# Example shape only: https://example-qdrant.cloud-provider.example
PRODUCTION_QDRANT_URL=

# Production CORS origins as a JSON array of public frontend origins.
# Example shape only: ["https://studio.example.com"]
PRODUCTION_CORS_ALLOWED_ORIGINS=[]

# Production trusted hosts as a JSON array of public backend/proxy hostnames.
# Example shape only: ["api.example.com","studio.example.com"]
PRODUCTION_TRUSTED_HOSTS=[]

# Production must enable API-key authentication.
PRODUCTION_API_AUTH_ENABLED=true

# Production API-key SHA-256 digest placeholder. Never store the plaintext key.
PRODUCTION_API_AUTH_KEY_SHA256=<sha256-hex-digest-placeholder>

# Production generation provider key placeholder. Store the real value privately.
PRODUCTION_OPENAI_API_KEY=<secret-managed-openai-key-placeholder>

# Vercel should use a lower function-safe upload limit and matching frontend value.
# Set these in Vercel environment variables, not in committed production files.
VERCEL_MAX_DOCUMENT_UPLOAD_BYTES=4000000
VERCEL_VITE_MAX_DOCUMENT_UPLOAD_BYTES=4000000
